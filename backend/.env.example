# Server Configuration
PORT=5000
NODE_ENV=development

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin Configuration (Required for Firebase database & authentication)
# Option A: Service Account File Path
# FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Option B: Inline service account details
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_CLIENT_EMAIL=your_firebase_client_email_here
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# Development Bypass Mode (Set to true to skip Firebase validation for testing)
DEV_MODE_BYPASS=true
